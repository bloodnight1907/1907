local lastShotTime = 0

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local char = LocalPlayer.Character
        if char and char:FindFirstChildOfClass("Tool") then
            lastShotTime = tick()
        end
    end
end)

if hookmetamethod then
    local __index
    __index = hookmetamethod(game, "__index", function(self, key)
        if not checkcaller() and self == LocalPlayer:GetMouse() and key == 'Hit' and S.Enabled then
            local now = tick()
            local shouldAim = not S.FlicksEnabled or (S.FlicksEnabled and now - lastShotTime <= 0.2)
            if shouldAim then
                local target = GetClosestForSilent()
                if target and target.Character then
                    local predictedPos = PredictPosition(target)
                    return CFrame.new(predictedPos)
                end
            end
        end
        return __index(self, key)
    end)
end

