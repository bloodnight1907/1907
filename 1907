-- Функция для принудительной установки нужного порядка во всех слотах
local function fixSlots()
    local backpack = localPlayer.Backpack
    if not backpack then return end

    -- Проверяем наличие каждого оружия в рюкзаке
    local shotgun = backpack:FindFirstChild("[Shotgun]")
    local doubleBarrel = backpack:FindFirstChild("[Double-Barrel SG]")
    local tactical = backpack:FindFirstChild("[TacticalShotgun]")
    local revolver = backpack:FindFirstChild("[Revolver]")

    if shotgun then
        MainEvent:FireServer("ChangeLoadout", "[Shotgun]", "Slot2")
        task.wait(0.1)
    end
    if doubleBarrel then
        MainEvent:FireServer("ChangeLoadout", "[Double-Barrel SG]", "Slot3")
        task.wait(0.1)
    end
    if tactical then
        MainEvent:FireServer("ChangeLoadout", "[TacticalShotgun]", "Slot4")
        task.wait(0.1)
    end
    if revolver then
        MainEvent:FireServer("ChangeLoadout", "[Revolver]", "Slot5")
        task.wait(0.1)
    end
end

