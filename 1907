function Slashes.AttachToCharacter(character)
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:WaitForChild("HumanoidRootPart", 2)
    if not rootPart then return end
    local attachment = rootPart:FindFirstChild("RootAttachment") or rootPart:WaitForChild("RootAttachment", 1)
    Slashes.SetupEmitters(attachment or rootPart)
end

function Slashes.Activate()
    Slashes.active = true
    local lp = LocalPlayer

    local function HandleCharacter(char)
        local function DelayedAttach()
            if Slashes.active and lp.Character == char then
                Slashes.AttachToCharacter(char)
            end
        end

        task.delay(0.25, DelayedAttach)
        task.delay(0.6, DelayedAttach)
        task.delay(1, DelayedAttach)

        if Slashes.desc_conn then
            Slashes.desc_conn:Disconnect()
            Slashes.desc_conn = nil
        end

        Slashes.desc_conn = char.DescendantAdded:Connect(function(desc)
            if not Slashes.active or lp.Character ~= char then return end
            if desc.Name == "RootAttachment" or (desc:IsA("Attachment") and desc.Parent and desc.Parent.Name == "HumanoidRootPart") then
                Slashes.AttachToCharacter(char)
                if Slashes.desc_conn then
                    Slashes.desc_conn:Disconnect()
                    Slashes.desc_conn = nil
                end
            end
        end)

        task.delay(3, function()
            if Slashes.desc_conn then
                Slashes.desc_conn:Disconnect()
                Slashes.desc_conn = nil
            end
        end)
    end

    if not Slashes.conn then
        Slashes.conn = lp.CharacterAdded:Connect(function(newChar)
            task.wait(0.5)
            if Slashes.active and lp.Character == newChar then
                Slashes.AttachToCharacter(newChar)
                HandleCharacter(newChar)
            end
        end)
    end

    if Slashes.appearance_conn then
        Slashes.appearance_conn:Disconnect()
        Slashes.appearance_conn = nil
    end

    Slashes.appearance_conn = lp.CharacterAppearanceLoaded:Connect(function(loadedChar)
        task.delay(0.2, function()
            local currentChar = lp.Character
            if Slashes.active and currentChar == loadedChar then
                Slashes.AttachToCharacter(loadedChar)
                HandleCharacter(loadedChar)
            end
        end)
    end)

    if lp.Character then
        Slashes.AttachToCharacter(lp.Character)
        HandleCharacter(lp.Character)
    end
end

function Slashes.Deactivate()
    Slashes.active = false

    if Slashes.conn then
        Slashes.conn:Disconnect()
        Slashes.conn = nil
    end

    if Slashes.appearance_conn then
        Slashes.appearance_conn:Disconnect()
        Slashes.appearance_conn = nil
    end

    if Slashes.desc_conn then
        Slashes.desc_conn:Disconnect()
        Slashes.desc_conn = nil
    end

    Slashes.StopRainbow()
    Slashes.ClearEmitters()
end

function Slashes.UpdateColor(color)
    Slashes.color = color
    if not Slashes.rainbow then
        Slashes.ApplyColor(color)
    end
end

