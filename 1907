UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    
    -- Открыть/закрыть GUI
    if input.KeyCode == Enum.KeyCode.End then
        if not ScreenGui or not ScreenGui.Parent then
            CreateGUI()
        else
            ScreenGui.Enabled = not ScreenGui.Enabled
        end
    end
    
    -- Переключение автошота
    if input.KeyCode == ToggleKey then
        ToggleAutoshot()
    end
    
    -- Ожидание нового бинда для автошота
    if WaitingForBind then
        ToggleKey = input.KeyCode
        if BindBtn then
            BindBtn.Text = "Сменить бинд (" .. ToggleKey.Name .. " - " .. BindMode .. ")"
        end
        WaitingForBind = false
    end
end)

-- ================================================
-- Обработка комбинаций F1+Z и F1+K
-- ================================================
local emojiKey1Down = false
local emojiKey2Down = false

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    -- Для F1+Z (выбор хоста)
    if input.KeyCode == SelectHostKey1 then
        key1Down = true
    end
    if input.KeyCode == SelectHostKey2 then
        key2Down = true
    end
    
    -- Для F1+K (эмодзи)
    if input.KeyCode == Enum.KeyCode.F1 then
        emojiKey1Down = true
    end
    if input.KeyCode == Enum.KeyCode.K then
        emojiKey2Down = true
    end
    
    -- Обработка F1+Z
    if key1Down and key2Down and HostSelectHotkeyEnabled then
        local closest = GetClosestPlayerToCrosshair()
        if closest then
            -- Проверяем, разрешено ли выбирать друзей
            if not AllowFriendsAsHost and IsFriend(closest) then
                -- Игнорируем друзей если запрещено
            else
                StarterPlayer = closest
                LastAmmoPerTool = {}
                if EmojiVisible then
                    AttachEmojiToPlayer(closest)
                end
            end
        end
        -- Сбрасываем флаги
        key1Down = false
        key2Down = false
    end
    
    -- Обработка F1+K
    if emojiKey1Down and emojiKey2Down then
        EmojiVisible = not EmojiVisible
        ShowTargetEmoji = EmojiVisible
        
        if EmojiVisible then
            if StarterPlayer then
                AttachEmojiToPlayer(StarterPlayer)
            end
        else
            RemoveEmoji()
        end
        
        -- анти-спам
        task.delay(0.3, function()
            emojiKey1Down = false
            emojiKey2Down = false
        end)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    -- Сброс флагов для F1+Z
    if input.KeyCode == SelectHostKey1 then
        key1Down = false
    end
    if input.KeyCode == SelectHostKey2 then
        key2Down = false
    end
    
    -- Сброс флагов для F1+K
    if input.KeyCode == Enum.KeyCode.F1 then
        emojiKey1Down = false
    end
    if input.KeyCode == Enum.KeyCode.K then
        emojiKey2Down = false
    end
end)

-- При смене хоста
local oldStarterPlayer = nil
RunService.RenderStepped:Connect(function()
    if StarterPlayer ~= oldStarterPlayer then
        oldStarterPlayer = StarterPlayer
        if EmojiVisible and StarterPlayer then
            AttachEmojiToPlayer(StarterPlayer)
        end
    end
end)

